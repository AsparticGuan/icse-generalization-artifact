# agent/.env — 完全替代 init_agent_env.sh + init_env.sh
#
# 使用方法：
#   cp agent/.env.example agent/.env
#   编辑下方变量，然后直接运行：python agent/run.py <issue_id>
#
# 优先级：系统环境变量 > 本文件 > env_config.py 代码默认值
# 带 # 注释的行为可选项，取消注释即可覆盖默认值。

# ═══════════════════════════════════════════════════════════════
# LLM 配置（必填）
# ═══════════════════════════════════════════════════════════════
# API 密钥
LAB_LLM_TOKEN=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

# API 端点
# - OpenAI 官方：https://api.openai.com/v1
# - OpenRouter：https://openrouter.ai/api/v1
# - 自建端点：填写完整 URL
LAB_LLM_URL=https://openrouter.ai/api/v1

# 模型名（直接传给 litellm）
# 常用值：gpt-4o / gpt-4.1 / deepseek/deepseek-v3.2
# anthropic/claude-sonnet-4.5 
# google/gemini-3-pro-preview
# qwen/qwen3.5-397b-a17b
# 若 LAB_LLM_URL 为自建端点，将按原样透传该模型名（支持有前缀或无前缀）
# 例如：openai/gpt-5.3-codex / qwen3.5-plus
LAB_LLM_MODEL=z-ai/glm-5

# LLM 温度（0.0–1.0）
# LAB_LLM_TEMP=0.6

# 基础模型知识截止日期（用于过滤 post-cutoff 知识）
# LAB_LLM_BASEMODEL_CUTOFF=1970-12-31Z

# ═══════════════════════════════════════════════════════════════
# Agent 行为
# ═══════════════════════════════════════════════════════════════
# 每个 issue 最大步数（1 step = 1 次 LLM 调用 + 1 次 bash 执行）
# LAB_AGENT_STEP_LIMIT=30

# 每个 issue 最大成本（美元）
# LAB_AGENT_COST_LIMIT=5.0

# 并行构建线程数（默认 = CPU 核数）
# LAB_MAX_BUILD_JOBS=8

# ═══════════════════════════════════════════════════════════════
# mini-swe-agent 全局安全限制
# ═══════════════════════════════════════════════════════════════
# 全局成本上限（美元），超过后 mini-swe-agent 拒绝继续调用
# MSWEA_GLOBAL_COST_LIMIT=10.0

# 全局 LLM 调用次数上限（0 表示不限制）
# MSWEA_GLOBAL_CALL_LIMIT=0

# ═══════════════════════════════════════════════════════════════
# 核心路径（通常使用默认值即可）
# ═══════════════════════════════════════════════════════════════
# 基础 LLVM 源码目录（用于 per-issue 克隆的种子仓库）
# 默认：<project_root>/utils/llvm/llvm-project
# LAB_LLVM_DIR=

# 构建目录根路径（每个 issue 会在其下创建子目录）
# 默认：<project_root>/build
# LAB_LLVM_BUILD_DIR=

# 数据集目录
# Agent 运行时固定使用：<project_root>/dataset（与 pipeline 对齐）
# 该路径不再通过 .env 覆盖。

# 定位分析输出文件（可选）
# LAB_LOCALIZE_OUTPUT=

# 若 LAB_LOCALIZE_OUTPUT 缺失当前 issue，是否在 agent 运行时执行 pipeline-style 二阶段定位（文件 -> 函数）
# LAB_AGENT_RUNTIME_LOCALIZE=ON

# 运行时定位超参数
# LAB_AGENT_LOCALIZE_TOP_K_FILES=3
# LAB_AGENT_LOCALIZE_TOP_K_FUNCS=3
# LAB_AGENT_LOCALIZE_MAX_FILE_CHARS=120000
# LAB_AGENT_LOCALIZE_TIMEOUT=120

# ═══════════════════════════════════════════════════════════════
# 外部工具路径（首次运行前需要构建，见 README）
# ═══════════════════════════════════════════════════════════════
# Alive2 语义验证工具
# 默认：<project_root>/utils/alive2/build/alive-tv
# LAB_LLVM_ALIVE_TV=

# 代价分析工具
# 默认：<project_root>/utils/cost/cost
# LAB_LLVM_COST_TOOL=

# ═══════════════════════════════════════════════════════════════
# 输出目录（留空则根据模型名自动生成）
# ═══════════════════════════════════════════════════════════════
# 修复结果 JSON 目录
# 默认：<project_root>/results/agent/fixes-<model>-agent
# LAB_FIX_DIR_AGENT=

# Agent 轨迹 JSON 目录
# 默认：<project_root>/results/agent/traj-<model>-agent
# LAB_TRAJ_DIR_AGENT=
