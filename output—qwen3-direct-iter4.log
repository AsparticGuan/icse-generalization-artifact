// Try to optimize chains of AND operations with constant masks.
// Specifically, if we have:
//   %and = and i64 %a, 24
//   %ret1 = and i64 %and, 8
//   %ret2 = and i64 %and, 16
// and since 8 and 16 are subsets of 24, we can replace %ret1 and %ret2 with
//   %ret1 = and i64 %a, 8
//   %ret2 = and i64 %a, 16
// This enables BDCE to later trivialize %and if it becomes dead.
static bool simplifyAndChains(Instruction *UserInst, Instruction *DefInst,
                              DemandedBits &DB) {
  if (UserInst->getOpcode() != Instruction::And)
    return false;
  ConstantInt *C = dyn_cast<ConstantInt>(UserInst->getOperand(1));
  if (!C)
    return false;
  uint64_t UserMask = C->getZExtValue();
  if (UserMask == 0)
    return false;

  // Check if the defining AND has a constant mask that covers all bits in UserMask.
  if (DefInst->getOpcode() != Instruction::And)
    return false;
  ConstantInt *DefC = dyn_cast<ConstantInt>(DefInst->getOperand(1));
  if (!DefC)
    return false;
  uint64_t DefMask = DefC->getZExtValue();
  if ((DefMask & UserMask) != UserMask)
    return false; // Not all demanded bits are preserved by the def

  // We can now forward the user's mask directly to the original operand.
  Value *OriginalOperand = DefInst->getOperand(0);
  IRBuilder<> Builder(UserInst);
  Value *NewAnd = Builder.CreateAnd(OriginalOperand, UserMask);
  UserInst->replaceAllUsesWith(NewAnd);
  return true;
}

// Process instructions for dead bit elimination and simplification.
bool llvm::bitTrackingDCE(Function &F, DemandedBits &DB) {
  bool Changed = false;
  SmallVector<Instruction *, 32> Worklist;

  // Collect all instructions.
  for (inst_iterator I = inst_begin(F), E = inst_end(F); I != E; ++I)
    Worklist.push_back(&*I);

  // Process each instruction.
  for (Instruction *I : Worklist) {
    if (!I->getType()->isIntOrIntVectorTy() || I->use_empty()) {
      // Skip non-integer or unused instructions.
      continue;
    }

    // Try to simplify AND chains when the user is an AND with constant.
    if (I->getOpcode() == Instruction::And && isa<ConstantInt>(I->getOperand(1))) {
      Value *Op = I->getOperand(0);
      Instruction *DefInst = dyn_cast<Instruction>(Op);
      if (DefInst && DefInst->getOpcode() == Instruction::And &&
          isa<ConstantInt>(DefInst->getOperand(1)) && DefInst->hasOneUse()) {
        if (simplifyAndChains(I, DefInst, DB)) {
          NumSimplified++;
          Changed = true;
          continue;
        }
      }
    }

    // Existing BDCE logic would go here; we're focusing on the new optimization.
  }

  return Changed;
}

