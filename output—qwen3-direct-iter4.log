```llvm
define i8 @avg_lsb(i8 %a, i8 %b) {
  %rem = and i8 %a, 1
  %rem1 = and i8 %b, 1
  %add = add nuw nsw i8 %rem1, %rem
  %div2 = lshr i8 %add, 1
  ret i8 %div2
}

```

