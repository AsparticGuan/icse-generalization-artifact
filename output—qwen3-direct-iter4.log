// Helper function to check if an AND operation can be simplified by known bits.
static bool simplifyAndWithKnownBits(Instruction *I, DemandedBits &DB) {
  if (I->getOpcode() != Instruction::And)
    return false;

  Value *Op0 = I->getOperand(0);
  Value *Op1 = I->getOperand(1);
  ConstantInt *C = dyn_cast<ConstantInt>(Op1);
  if (!C)
    return false;

  // If this AND has a constant mask, see if we can propagate the mask backwards
  // through another AND if the outer AND only demands bits that are already
  // covered by the inner constant.
  uint64_t Mask = C->getZExtValue();
  if (Mask == 0)
    return false;

  // Check if the first operand is another AND with a constant.
  Instruction *OuterAnd = dyn_cast<Instruction>(Op0);
  if (!OuterAnd || OuterAnd->getOpcode() != Instruction::And ||
      !OuterAnd->hasOneUse() || !OuterAnd->getType()->isIntegerTy())
    return false;

  Value *InnerOp1 = OuterAnd->getOperand(1);
  ConstantInt *InnerC = dyn_cast<ConstantInt>(InnerOp1);
  if (!InnerC)
    return false;

  uint64_t InnerMask = InnerC->getZExtValue();
  // If the inner mask already covers all bits demanded by the outer AND,
  // we can replace the outer AND with a direct use of the original operand.
  if ((InnerMask & Mask) == Mask) {
    // We can forward the outer AND mask directly to the input of the inner AND.
    IRBuilder<> Builder(OuterAnd);
    Value *Original = OuterAnd->getOperand(0);
    Value *NewAnd = Builder.CreateAnd(Original, Mask);
    I->replaceAllUsesWith(NewAnd);
    // Note: We don't remove OuterAnd here because it may have other uses.
    // But in this case, since we require OuterAnd has one use (this AND),
    // we can safely eliminate it later if no longer used.
    return true;
  }
  return false;
}

