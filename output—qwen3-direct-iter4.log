Instruction *InstCombinerImpl::visitCallInst(CallInst &CI) {
  Function *Callee = CI.getCalledFunction();
  if (!Callee || !Callee->isIntrinsic())
    return nullptr;

  if (Callee->getIntrinsicID() != Intrinsic::vector_reduce_add)
    return nullptr;

  Value *VecOp = CI.getOperand(0);
  VectorType *VecTy = cast<VectorType>(VecOp->getType());
  unsigned NumElements = VecTy->getNumElements();
  Type *ScalarTy = VecTy->getElementType();

  // Look through insertelement + shufflevector pattern that creates a splat
  Value *SplatVal = nullptr;
  if (isa<InsertElementInst>(VecOp->getOperand(0))) {
    InsertElementInst *IE = cast<InsertElementInst>(VecOp->getOperand(0));
    if (IE->getOperand(2)->isZero() && isa<ShuffleVectorInst>(VecOp)) {
      ShuffleVectorInst *SV = cast<ShuffleVectorInst>(VecOp);
      if (SV->getOperand(1)->isPoison() && SV->getShuffleMask().isZero())
        SplatVal = IE->getOperand(1);
    }
  }

  if (!SplatVal)
    return nullptr;

  // Reduction of N copies of X is N * X.
  Constant *NumElementsC = ConstantInt::get(ScalarTy, NumElements);
  Value *Mul = Builder.CreateMul(SplatVal, NumElementsC);
  return replaceInstUsesWith(CI, Mul);
}
