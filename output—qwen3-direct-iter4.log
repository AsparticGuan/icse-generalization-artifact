        isGuaranteedNotToBeUndef(Op0, Q.AC, Q.CxtI, Q.DT, Depth + 1);
  Known = KnownBits::mul(Known, Known2, SelfMultiply);

  // Only make use of no-wrap flags if we failed to compute the sign bit
  // directly.  This matters if the multiplication always overflows, in
  // which case we prefer to follow the result of the direct computation,
  // though as the program is invoking undefined behaviour we can choose
  // whatever we like here.
  if (isKnownNonNegative && !Known.isNegative())
    Known.makeNonNegative();
  else if (isKnownNegative && !Known.isNonNegative())
    Known.makeNegative();

  // For self-multiplication of a sign-extended i8, we can derive tighter constraints.
  // Specifically, if we have %mul = sext(%x) * sext(%x), where %x is i8,
  // then %mul is always in [0, 16384], and bit 14 (16384) is set iff %mul > 16383.
  // This allows transforming (and %mul, 16384) != 0 into %mul > 16383.
  if (SelfMultiply) {
    // Check if the operand is a sext from i8
    if (auto *SExt = dyn_cast<SExtInst>(Op0)) {
      if (SExt->getSrcTy()->getIntegerBitWidth() == 8) {
        // The maximum value after sext and square is 128*128 = 16384.
        // So the result is in [0, 16384], and bit 14 being set means exactly that the value is 16384.
        // Therefore, (mul & 16384) != 0  <=>  mul == 16384  <=>  mul > 16383.
        // We can reflect that by ensuring higher bits (above 14) are known zero.
        unsigned BitWidth = Known.getBitWidth();
        for (unsigned i = 15; i < BitWidth; ++i)
          Known.Zero.setBit(i);
        // Also, since the square is non-negative, ensure that.
        Known.makeNonNegative();
      }
    }
  }
}

