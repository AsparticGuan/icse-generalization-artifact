    // bitcast x -> x
    if (CastOpc == Instruction::BitCast)
      if (Op->getType() == Ty)
        return Op;

    // Optimize ptrtoint patterns involving GEP and subtraction.
    // Recognize:
    //   %ptr.addr = ptrtoint %ptr to i64
    //   %size = sub %end.addr, %ptr.addr
    //   %end = gep %ptr, %size
    //   %end.addr2 = ptrtoint %end to i64  --> simplify to %end.addr
    if (CastOpc == Instruction::PtrToInt && Ty->isIntegerTy()) {
      if (GetElementPtrInst *GEP = dyn_cast<GetElementPtrInst>(Op)) {
        Value *Ptr = GEP->getPointerOperand();
        Value *Idx = GEP->getOperand(1);
        if (BinaryOperator *Sub = dyn_cast<BinaryOperator>(Idx)) {
          if (Sub->getOpcode() == Instruction::Sub) {
            Value *EndAddr = Sub->getOperand(0);
            Value *PtrToInt = Sub->getOperand(1);
            if (PtrToIntInst *PTI = dyn_cast<PtrToIntInst>(PtrToInt)) {
              if (PTI->getOperand(0) == Ptr) {
                // Found pattern: ptrtoint(gep(ptr, end - ptrtoint(ptr))) -> end
                return EndAddr;
              }
            }
          }
        }
      }
    }

    return nullptr;
}

