Instruction *InstCombinerImpl::visitCallInst(CallInst &CI) {
  Function *Callee = CI.getCalledFunction();
  if (!Callee || !Callee->isIntrinsic())
    return nullptr;

  switch (Callee->getIntrinsicID()) {
  case Intrinsic::vector_reduce_add: {
    Value *VecOp = CI.getOperand(0);
    VectorType *VecTy = cast<VectorType>(VecOp->getType());
    unsigned NumElements = VecTy->getNumElements();
    Constant *C = dyn_cast<Constant>(VecOp);
    if (!C)
      break;

    // If the vector is formed by splatting a single value, we can fold the reduction.
    Constant *SplatVal = C->getSplatValue();
    if (!SplatVal)
      break;

    // Reduction of N copies of X is N * X.
    Type *ScalarTy = VecTy->getElementType();
    Constant *NumElementsC = ConstantInt::get(ScalarTy, NumElements);
    Value *Mul = Builder.CreateMul(SplatVal, NumElementsC);
    return replaceInstUsesWith(CI, Mul);
  }
  default:
    break;
  }

  return nullptr;
}
```
