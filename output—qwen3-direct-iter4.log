// Try to simplify AND chains by forwarding demanded bits through intermediate
// AND operations with constant masks. If an AND instruction only uses a subset
// of bits from another AND with a constant, and those bits are preserved,
// we can replace the use with an AND directly on the original operand.
static bool simplifyAndChains(Instruction *I, DemandedBits &DB) {
  if (I->getOpcode() != Instruction::And)
    return false;

  // We are interested in cases where:
  //   %and = and X, C1
  //   %res = and %and, C2
  // and C2 is a subset of C1. Then we can replace %res with 'and X, C2'.
  Value *Op0 = I->getOperand(0);
  ConstantInt *C2 = dyn_cast<ConstantInt>(I->getOperand(1));
  if (!C2)
    return false;

  uint64_t Mask2 = C2->getZExtValue();
  if (Mask2 == 0)
    return false;

  Instruction *InnerAnd = dyn_cast<Instruction>(Op0);
  if (!InnerAnd || InnerAnd->getOpcode() != Instruction::And ||
      !InnerAnd->hasOneUse()) // Must have one use to avoid side effects
    return false;

  ConstantInt *C1 = dyn_cast<ConstantInt>(InnerAnd->getOperand(1));
  if (!C1)
    return false;

  uint64_t Mask1 = C1->getZExtValue();
  // If Mask1 includes all bits in Mask2, then we can forward Mask2 to the input
  if ((Mask1 & Mask2) == Mask2) {
    IRBuilder<> Builder(I);
    Value *Original = InnerAnd->getOperand(0);
    Value *NewAnd = Builder.CreateAnd(Original, Mask2);
    I->replaceAllUsesWith(NewAnd);
    return true;
  }
  return false;
}

